# ── QuantumWealth Django — Environment Variables ──────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.

# ─── Django Core ──────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-at-least-50-random-characters-here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com
DJANGO_SETTINGS_MODULE=quantumwealth.settings.production

# Frontend URL (used in email links)
FRONTEND_URL=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────────────────
DB_NAME=quantumwealth
DB_USER=qwuser
DB_PASSWORD=qwpassword
DB_HOST=localhost
DB_PORT=5432

# ─── Redis / Cache ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── JWT Token Lifetimes ──────────────────────────────────────────────────────
ACCESS_TOKEN_MINUTES=60
REFRESH_TOKEN_DAYS=7

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Market Data APIs ─────────────────────────────────────────────────────────
ALPHA_VANTAGE_API_KEY=demo
POLYGON_API_KEY=
FINNHUB_API_KEY=

# ─── AI / LLM ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ─── Email ────────────────────────────────────────────────────────────────────
# Development: use console backend
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Production: use SMTP or Anymail
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@quantumwealth.ai

# ─── AI Engine Config ─────────────────────────────────────────────────────────
AI_MARKET_DATA_PERIOD=2y
AI_MONTE_CARLO_DEFAULT_SIMS=10000
AI_SIMULATION_SEED=42
